generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminAccount {
  id               String    @id @default(uuid())
  username         String    @unique
  passwordHash     String
  displayName      String
  role             String    @default("ADMIN") // SUPER_ADMIN, ADMIN, MODERATOR, VIEWER
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  loginCount       Int       @default(0)
  passwordExpiresAt DateTime?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AdminLoginLog {
  id        String   @id @default(uuid())
  username  String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  endpoint  String
  method    String
  body      String?
  createdAt DateTime @default(now())
}
